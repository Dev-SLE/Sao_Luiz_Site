# Configurações de Ambiente

# String de conexão do banco de dados (PostgreSQL Neon)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# (Opcional) Banco dedicado para o módulo Comercial/Auditoria.
# Se vazio, usa DATABASE_URL.
COMERCIAL_DATABASE_URL=

# IA para o módulo Comercial (sugestão de plano de ação)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Robô Supremo (execução via site)
# Caminho absoluto do arquivo .py a ser executado pelo painel
ROBO_SUPREMO_PATH=
# Binário Python opcional (ex.: python, python3, C:\Python312\python.exe)
ROBO_SUPREMO_PYTHON_BIN=python

# (Opcional) Override do base URL da API no browser
# Por padrão, o app usa "/api" (mesmo domínio na Vercel).
# NEXT_PUBLIC_API_URL=https://seu-site.vercel.app/api

# Google OAuth (Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://seu-site.vercel.app/api/oauth2callback

# Google Drive
DRIVE_FOLDER_ID=