# Opcional: limite de conexões do pool pg (Neon/serverless). Padrão 10.
# PG_POOL_MAX=10

# Roles extras tratadas como administrador total (valor de `users.role`, separadas por vírgula).
# No cliente use também NEXT_PUBLIC_ADMIN_ROLE_ALIASES com os mesmos nomes para o menu e gates baterem com a API.
# Ex.: ADMIN_ROLE_ALIASES=Meu Perfil Admin,CRM Master
# NEXT_PUBLIC_ADMIN_ROLE_ALIASES=Meu Perfil Admin,CRM Master

# TTL (ms) do cache em memória das rotas CRM de leitura agregada (executive-kpis, productivity). Padrão 20000. Mín 500, máx 120000.
# CRM_READ_CACHE_TTL_MS=20000

# Contadores de rota/cache em memória (GET /api/diagnostics/route-meter). Use API_ROUTE_METER=0 para desligar.
# API_ROUTE_METER=1

# BI Comissões — COMERCIAL_DATABASE_URL, schema bi. Views e colunas oficiais ficam em modules/bi/comissoes/config.ts (versionado).
# Cache do catálogo information_schema (ms). 0 = reler a cada request. Padrão 120000.
# BI_COMISSOES_SCHEMA_CACHE_TTL_MS=120000
# 1 = ignora cache e relê o catálogo em toda chamada às rotas de dados (mais pesado).
# BI_COMISSOES_SCHEMA_INTROSPECT_EVERY_REQUEST=0
