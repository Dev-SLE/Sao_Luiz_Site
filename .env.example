# Configurações de Ambiente

# String de conexão do banco de dados (PostgreSQL Neon)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Assinatura HMAC do cookie de sessão (sle_session). Obrigatório em produção (NODE_ENV=production).
# Use um valor longo e aleatório; não reutilize EVOLUTION_WEBHOOK_TOKEN.
AUTH_SESSION_SECRET=

# (Opcional) Protege chamadas de manutenção disparadas por cron (ex.: Vercel Cron).
# Envie header: x-cron-secret: <mesmo valor>. Usado em /api/whatsapp/retry_outbox, /api/rebuild_cte_view_index,
# /api/operational_tracking/sync (Life) e /api/operational_tracking/sync_vehicle_from_ctes (placas via pendencias.ctes).
CRON_SECRET=

# (Uso local / CI, não na Vercel) Agregação de rotas OD: `python scripts/compute_route_patterns.py`
# — lê até ~30k linhas de posições e grava padrões enxutos no Neon; processamento pesado fora do Postgres.

# Rastreamento Life (Operacional - mapa com lat/lng)
# Token fornecido pela plataforma Life.
LIFE_TRACKING_TOKEN=
# Endpoint base da Life API (padrão homologado abaixo).
LIFE_TRACKING_API_URL=http://ws.lifeonline.com.br:6010/ws/rast_online/index.php

# (Opcional) Banco dedicado para o módulo Comercial/Auditoria.
# Se vazio, usa DATABASE_URL.
COMERCIAL_DATABASE_URL=

# IA (Sofia + módulo Comercial)
AI_PROVIDER=OPENAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Robô Supremo (execução via site)
# Caminho absoluto do arquivo .py a ser executado pelo painel
ROBO_SUPREMO_PATH=
# Binário Python opcional (ex.: python, python3, C:\Python312\python.exe)
ROBO_SUPREMO_PYTHON_BIN=python

# URL pública do site (Vercel) — usada em textos de webhook Evolution e sync. Sem barra no fim.
NEXT_PUBLIC_APP_URL=https://sao-luiz-site.vercel.app

# (Opcional) Override do base URL da API no browser
# Por padrão, o app usa "/api" (mesmo domínio na Vercel).
# NEXT_PUBLIC_API_URL=https://sao-luiz-site.vercel.app/api

# Google OAuth (Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://seu-site.vercel.app/api/oauth2callback

# Google Drive
DRIVE_FOLDER_ID=

# WhatsApp — linha oficial (Meta Cloud API) / Sofia
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Webhook Evolution API (linhas atendentes). Em produção use URL fixa, ex.:
# https://sao-luiz-site.vercel.app/api/whatsapp/evolution/webhook?token=...
# (Opcional) Se NEXT_PUBLIC_APP_URL não existir, pode repetir a base aqui:
# EVOLUTION_WEBHOOK_PUBLIC_BASE=https://sao-luiz-site.vercel.app
EVOLUTION_WEBHOOK_TOKEN=
# No Manager da Evolution, inclua na URL do webhook: MESSAGES_UPSERT, MESSAGES_UPDATE, MESSAGES_EDITED
# (edições de mensagem só sincronizam com MESSAGES_EDITED / updates com texto).

# Servidor Evolution (URL pública em produção, ex. Railway/VPS — não use localhost na Vercel)
# Usados pelo CRM em "modo rápido" (usuários não digitam URL/chave — só nome da linha + QR).
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=
# Opcional: aliases iguais aos acima (se preferir nome explícito "default")
# EVOLUTION_DEFAULT_SERVER_URL=
# EVOLUTION_DEFAULT_API_KEY=

# Obrigatório na Vercel para /evolution-pairing e sync-webhook (connect + qr-last no servidor)
EVOLUTION_CONNECT_PROXY_ENABLED=true

# Anti-poluição de leads via WhatsApp Web (Evolution):
# OFF = comportamento antigo (cria lead para todo contato novo)
# BUSINESS_ONLY = cria só quando houver sinal de negócio (padrão recomendado)
# AGENCY_ONLY = cria apenas se o número estiver cadastrado em crm_agencies
CRM_EVOLUTION_LEAD_FILTER_MODE=BUSINESS_ONLY
# Fallback caso não configure no painel (Configurações -> Operação CRM)
CRM_EVOLUTION_INTAKE_AI_ENABLED=true
# Opcional: força criar mesmo sem sinal (lista de números, separados por vírgula)
CRM_EVOLUTION_LEAD_ALLOWLIST_LAST10=
# Opcional: nunca criar lead para estes números (lista de números, separados por vírgula)
CRM_EVOLUTION_LEAD_DENYLIST_LAST10=

# (Servidor Evolution, não é Next.js) — use no Docker deploy/docker-compose.evolution.yml
# AUTHENTICATION_API_KEY=