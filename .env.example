# Mínimo que costuma faltar para CRM + Evolution (mídia com URL assinada).
# O resto (Meta, OpenAI, Graph/SharePoint, etc.) define-se conforme os módulos que usas.

# Base de dados e sessão (obrigatório em produção)
# DATABASE_URL=
# AUTH_SESSION_SECRET=

# Evolution — API do servidor e autenticação do webhook
# EVOLUTION_API_URL=
# EVOLUTION_API_KEY=
# EVOLUTION_WEBHOOK_TOKEN=

# Se a Evolution enviar no JSON um `apikey` diferente do token da URL:
# EVOLUTION_WEBHOOK_ACCEPT_APIKEY=

# Obrigatório para links assinados de mídia Evolution (/api/crm/evolution-media/...).
# Sem isto, mídia tende a ficar em data URI ou sem URL estável. Mínimo 16 caracteres.
# FILES_EVOLUTION_DOWNLOAD_SECRET=

# URL pública do CRM (links de mídia). Na Vercel costuma bastar VERCEL_URL; define isto se quiseres domínio fixo.
# NEXT_PUBLIC_APP_URL=
